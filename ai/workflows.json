      "prompt_path": "prompts/workshop-design.md",
      "read_before_running": [
        "ai/system-instructions.md",
        "ai/context-brief.md",
        "ai/manifest.json",
        "ai/context-full.md",
        "ai/rag/chunks.jsonl",
        "metadata/report-sidecars/*.json",
        "metadata/reports.json",
        "prompts/workshop-design.md"
      ],
      "input_contract": [],
      "output_contract": [
        "ワークショップ名",
        "対象者",
        "ねらい",
        "使用するレポート",
        "concept_alignment",
        "タイムテーブル",
        "個人活動・グループ活動",
        "成果物",
        "リスクと対策"
      ],
      "evidence_policy": {
        "prefer": [
          "ai/rag/chunks.jsonl",
          "metadata/report-sidecars/*.json",
          "ai/citations.json",
          "reports/*.md"
