{
  "schema": "aice.ai_workflows.v1",
  "description": "AIエージェントが用途別プロンプトを選び、必要資料と出力契約を確認するための機械可読ワークフロー索引。",
  "default_read_order": [
    "ai/system-instructions.md",
    "ai/manifest.json",
    "ai/context-brief.md",
    "ai/workflows.json"
  ],
  "workflows": [
    {
      "id": "lesson-plan-generation",
      "purpose": "指定した学年・教科・時間数に合わせ、レポートの根拠を示しながら授業案を組み立てるための授業設計支援",
      "prompt_path": "prompts/lesson-plan-generation.md",
      "read_before_running": [
        "ai/system-instructions.md",
        "ai/context-brief.md",
        "ai/manifest.json",
        "ai/context-full.md",
        "ai/rag/chunks.jsonl",
        "metadata/report-sidecars/*.json",
        "metadata/reports.json",
        "prompts/lesson-plan-generation.md"
      ],
      "input_contract": [],
      "output_contract": [
        "授業名",
        "対象学年・教科",
        "到達目標",
        "参照レポートと根拠チャンク",
        "concept_alignment",
        "時間配分",
        "学習活動",
        "AI利用の役割",
        "評価観点",
        "倫理・著作権・安全上の配慮"
      ],
      "evidence_policy": {
        "prefer": [
          "ai/rag/chunks.jsonl",
          "metadata/report-sidecars/*.json",
          "ai/citations.json",
          "reports/*.md"
        ],
        "cite_with": [
          "report_id",
          "chunk_id",
          "evidence_refs",
          "figure_ids"
        ],
        "mark_unsourced_claims_as_inference": true,
        "human_verification_required": true
      }
    },
    {
